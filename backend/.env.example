# OpenWeatherMap API configuration
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Gemini AI API configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Default coordinates for Malaysia (Kuala Lumpur)
MALAYSIA_LAT=3.1390
MALAYSIA_LON=101.6869

# Weather update interval (in seconds)
WEATHER_UPDATE_INTERVAL=300  # Update weather every 5 minutes

# Unsplash API configuration (for fetching bird images)
UNSPLASH_API_KEY=your_unsplash_api_key_here

